// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
//idempotency key contain its id(key), responseBody, responseStatus, createdAt
model IdempotencyKey {
  key     String     @id 
  responseBody   Json?    
  responseStatus    Int?
  createdAt DateTime    @default(now())

@@index([createdAt])
}


model EmailLog {
  id      String     @id @default(uuid())
  recipient   String 
  eventType    String       //depends on the microservice, example: USER_REGISTERED
  status      String    @default("QUEUED")     //TODO: convert into enum, QUEUED, PROCESSING, DELIVERED , FAILED, BOUNCED
  provider    String?
  errorReason   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt


  @@index([recipient])
}



model SupressionList {
  email     String    @id 
  reason     String    //bounce, complaint   (enum?)
  createdAt    DateTime    @default(now())
}